{
  "compilerOptions": {
    "target": "ES6",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "rootDir": "./src/ts",
    "outDir": "./website/js",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "removeComments": false,
    "sourceMap": false
  },
  "include": ["src/ts/**/*"]
}
